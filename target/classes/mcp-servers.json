{
  "mcpServers": {
    "dbhub": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--init",
        "--pull=always",
        "--name",
        "dbhub",
        "--publish",
        "9080:9080",
        "bytebase/dbhub",
        "--transport"
      , "stdio",
        "--port"
      , "9080",
        "--dsn",
        "mysql://root:1234@host.docker.internal:3306/control_asistencia?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC"
      ]
    }
  }
}